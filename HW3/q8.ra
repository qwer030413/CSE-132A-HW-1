john :-
\project_{name}
(
    \select_{name = 'John Smith'} customer
);



john_borrowed :-
\project_{name}
(
    john \join_{name = cname} borrower
);

total :-
\rename_{borrowedAmount}
\project_{total}
(
    \rename_{name, total}
    \aggr_{name : sum(amount)}
    (
        (john \join_{name = cname} borrower)
        \join_{lno = no} loan
    )
);

zero :-
\rename_{borrowedAmount}
\project_{0}
(
    john \diff john_borrowed
);

total \union zero;